# Optional local overrides for your machine.
# Copy to local.env and change values as needed.
# Caution: only point these at networks/hosts you own or are authorized to test.

# NETWORK_CIDR=192.168.1.0/24

# SCAN_TARGET_IP=192.168.1.50
# SCAN_PORTS=22,80,443,1883,8554,14550

# TCP_PROBE_HOST=192.168.1.50
# TCP_PROBE_PORT=22
# TCP_PROBE_TIMEOUT_SECONDS=2

# UDP_PROBE_HOST=192.168.1.50
# UDP_PROBE_PORT=14550
# UDP_PROBE_TIMEOUT_SECONDS=2

# HTTP_PROBE_URL=http://192.168.1.50:8080

# DNS_LOOKUP_NAME=example.com

# ETH_INTERFACE=eth0
# WIFI_INTERFACE=wlan0
