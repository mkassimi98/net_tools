# Shared defaults for network-discovery scripts (bash + python)
# CLI args still override these values.
# Caution: only point these at networks/hosts you own or are authorized to test.

# Leave NETWORK_CIDR empty to auto-detect the local subnet from `ip addr`.
NETWORK_CIDR=

SCAN_TARGET_IP=127.0.0.1
SCAN_PORTS=22,80,443,1883,8554,14550

TCP_PROBE_HOST=127.0.0.1
TCP_PROBE_PORT=22
TCP_PROBE_TIMEOUT_SECONDS=2

UDP_PROBE_HOST=127.0.0.1
UDP_PROBE_PORT=14550
UDP_PROBE_TIMEOUT_SECONDS=2

HTTP_PROBE_URL=http://example.com

DNS_LOOKUP_NAME=example.com

# Leave blank to auto-detect the primary wired and WiFi interfaces.
ETH_INTERFACE=
WIFI_INTERFACE=
