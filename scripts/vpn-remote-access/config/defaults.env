# Shared defaults for vpn-remote-access scripts (bash + python)
# CLI args still override these values.

# Default VPN tunnel for the recording demos.
VPN_INTERFACE=tun1

# VPN server / reachability target used in the demo captures.
VPN_PING_TARGET=1.0.0.1
VPN_PING_COUNT=4

# SSH target reachable through the VPN (optional demo).
VPN_SSH_TARGET=
