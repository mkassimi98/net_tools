# Shared defaults for vpn-remote-access scripts (bash + python)
# CLI args still override these values.

# Leave blank to auto-detect tun*/wg* interfaces.
VPN_INTERFACE=

# Target to ping/reach through the VPN to verify connectivity.
VPN_PING_TARGET=8.8.8.8
VPN_PING_COUNT=4

# SSH target reachable through the VPN (optional demo).
VPN_SSH_TARGET=
