# Shared defaults for traffic-capture-analysis scripts (bash + python)
# CLI args still override these values.

CAPTURE_INTERFACE=any
CAPTURE_PACKET_COUNT=20
ICMP_CAPTURE_PACKET_COUNT=8
TCP_CAPTURE_PACKET_COUNT=20
UDP_CAPTURE_PACKET_COUNT=2
CAPTURE_TIMEOUT_SECONDS=12
PING_COUNT=4
PING_TARGET=8.8.8.8

TCP_TARGET_HOST=example.com
TCP_TARGET_PORT=443

UDP_TARGET_HOST=8.8.8.8
UDP_TARGET_PORT=53
UDP_QUERY_NAME=example.com

TSHARK_INTERFACE=any
TSHARK_PACKET_COUNT=20

IPERF3_SERVER=127.0.0.1
IPERF3_PORT=5201
IPERF3_DURATION_SECONDS=5

MTR_TARGET=8.8.8.8
MTR_CYCLES=10

TRACEPATH_TARGET=8.8.8.8
TRACEPATH_TIMEOUT_SECONDS=20

REALTIME_INTERFACE=any
REALTIME_SECONDS=8
